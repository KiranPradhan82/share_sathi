# Database (Turso - libsql)
DATABASE_URL=libsql://your-db-name.your-region.turso.io?authToken=your-auth-token-here

# Cron secret (required for Vercel cron jobs to authenticate)
# Vercel sends this as Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Auth reset secret (used to reset forgotten password via /api/auth/reset-password)
# Can be the same as CRON_SECRET or a different value
AUTH_RESET_SECRET=your-random-secret-here