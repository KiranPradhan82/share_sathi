# Database (Turso - libsql)
DATABASE_URL=libsql://your-db-name.your-region.turso.io?authToken=your-auth-token-here

# Cron secret (required for Vercel cron jobs to authenticate)
# Vercel sends this as Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Gmail (for password reset emails)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an App Password (select "Mail" + "Other")
# 3. Use the 16-char password below
GMAIL_EMAIL=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx